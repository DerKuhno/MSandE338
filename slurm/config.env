# ============================================================
# Shared configuration for all Slurm jobs.
# Source this file at the top of every sbatch script.
# ============================================================

# --- Paths -----------------------------------------------------------
# Root directory for all generated data, models, and cache.
# Must be on a shared filesystem visible to all compute nodes (e.g. Lustre/NFS).
export WORKSPACE_DIR="${WORKSPACE_DIR:-/lustre/fsw/portfolios/sw/projects/sw_aidot/users/hsahota/cs338/workspace}"

# Derived paths (override individually if needed).
export CACHE_DIR="$WORKSPACE_DIR/.cache"
export DATASET_DIR="$WORKSPACE_DIR/datasets"
export MODEL_DIR="$WORKSPACE_DIR/models/non-wmdp"
export WMDP_MODEL_DIR="$WORKSPACE_DIR/models/wmdp"

# pip packages installed once into the shared filesystem so every container
# job can import them without reinstalling each time.
export PIP_ENV="$WORKSPACE_DIR/pip_env"

# --- Repo ------------------------------------------------------------
# Absolute path to the cloned repository.
export REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." ; pwd)"

# --- Container -------------------------------------------------------
# Path to the PyTorch Squashfs container image (used with enroot/pyxis).
export CONTAINER_IMAGE="${CONTAINER_IMAGE:-/lustre/fsw/portfolios/sw/users/hsahota/containers/cs338.sqsh}"

# Mounts passed to srun --container-mounts.
# Expose the repo and workspace inside the container at the same paths.
export CONTAINER_MOUNTS="${REPO_DIR}:${REPO_DIR},${WORKSPACE_DIR}:${WORKSPACE_DIR}"

# --- Slurm ---------------------------------------------------------
# Partition/account/QOS are NOT set here — use your shell alias or
# set SBATCH_* vars in ~/.cs338_slurm.env before submitting.

# Number of GPUs for training jobs.
# 1 GPU is sufficient for the 0.1B model experiments.
export GPUS_PER_NODE="${GPUS_PER_NODE:-1}"
